# 复制为 .env 后填写本地 Demo 所需配置。
# 不要提交真实 API Key 或客户数据。

# Query analysis 与回答生成使用的 LLM 配置。
GOOGLE_API_KEY=
# GEMINI_API_KEY=
GOOGLE_LLM_MODEL=gemini-3-flash-preview
GOOGLE_QUERY_ANALYZER_MODEL=gemini-3-flash-preview

# ingest.py 与 rag_core.py 使用的 embedding provider。
# 当前代码支持：google | gemini | openai | zhipu | huggingface | bge_m3 | e5 | local_hash
EMBEDDING_PROVIDER=google
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# ZHIPU_API_KEY=
# ZHIPU_EMBEDDING_MODEL=embedding-2
# ZHIPU_OPENAI_BASE=https://open.bigmodel.cn/api/paas/v4/
# HF_EMBEDDING_MODEL=BAAI/bge-m3
# E5_EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_NORMALIZE=true
EMBEDDING_BATCH_SIZE=32
# LOCAL_HASH_EMBEDDING_DIM=384

# 文档解析。
# 默认走本地路线：PDF 使用 pdfplumber，Word 使用 python-docx；不会消耗 LlamaParse credits。
INGEST_PDFPLUMBER_FALLBACK=true

# 可选付费 / 云端解析服务。只有显式启用并配置 key 时才会尝试 LlamaParse。
INGEST_USE_LLAMAPARSE=false
# LLAMA_CLOUD_API_KEY=

# 本地向量库。
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=lab_literature_rag
# 单次全量重建可设为 true，也可以直接使用 `make rebuild`。
REBUILD_CHROMA=false

# 检索调参。
RAG_RETRIEVAL_MODE=hybrid
HYBRID_LEXICAL_POOL_LIMIT=20000
HYBRID_LEXICAL_WEIGHT=0.35
STRICT_PROTOCOL_APPENDIX=true
PAPER_PROTOCOL_K_MIN=12
PAPER_PROTOCOL_K_MAX=20
PAPER_MULTI_SOURCE_SUPPLEMENT_K=5
PAPER_MULTI_SOURCE_MAX_ADD=12

# Chunking
CHUNK_STRATEGY=header_aware
PAPER_CHUNK_STRATEGY=header_aware
SOP_CHUNK_STRATEGY=parent_child
PAPER_CHUNK_SIZE=900
PAPER_CHUNK_OVERLAP=150
SOP_CHILD_CHUNK_SIZE=500
SOP_CHILD_CHUNK_OVERLAP=80
SOP_PARENT_CHUNK_SIZE=1800
SOP_PARENT_CHUNK_OVERLAP=200
INGEST_METADATA_EXCERPT_CHARS=14000
DOCX_SEGMENT_CHARS=8000

# Reranker
RERANKER_PROVIDER=none
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
BGE_RERANKER_MODEL=BAAI/bge-reranker-base
RERANK_TOP_N=20
RERANK_RRF_K=60
FINAL_CONTEXT_K=8
RERANK_RULE_WEIGHT=0.35
HYBRID_MIN_PAPER_CHUNKS=2
HYBRID_MIN_SOP_CHUNKS=2

# Query-anchored paper retrieval
ANCHORED_PAPER_RETRIEVAL=true
ANCHORED_PAPER_MIN_CHUNKS=3
ANCHORED_PAPER_TITLE_BOOST=0.25
ANCHORED_SOURCE_SOFT_MATCH=true
HYBRID_PAPER_CANDIDATE_TOPN=20

# Evaluation
EVAL_TOP_K=5
EVAL_REPORT_DIR=eval/reports
