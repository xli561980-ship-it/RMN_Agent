.DS_Store
.env
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local/runtime artifacts
.cache/
chroma_db/
processed_files.json
corpus_manifest.json
