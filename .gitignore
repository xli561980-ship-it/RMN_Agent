# Generated exports at repo root; keep eval experiment reports versioned.
/reports/
!eval/reports/
!eval/reports/**

# Large/private corpora should stay out of git; keep directory placeholders.
data/papers/*
!data/papers/.gitkeep
data/manuals/*
!data/manuals/.gitkeep
data/private/
outputs/
