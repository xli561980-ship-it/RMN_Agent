.DS_Store
.env
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local/runtime artifacts
chroma_db/
processed_files.json
corpus_manifest.json
processed_files.json.tmp
corpus_manifest.json.tmp

# Large/private corpora and generated exports should be handled explicitly.
# Keep these ignored for publishable copies; remove locally only when needed.
data/papers/*
!data/papers/.gitkeep
data/manuals/*
!data/manuals/.gitkeep
data/private/
outputs/
reports/
eval/runs/

# Keep curated evaluation reports visible even though generic reports are ignored.
!eval/reports/
!eval/reports/**
